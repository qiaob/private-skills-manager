# Example source configuration
# Copy this file and rename to <source-name>.conf to use it.
#
# Minimal config (public repo via HTTPS):
#   REPO=https://github.com/org/skills-repo.git
#   BRANCH=main
#   SKILLS_SUBDIR=skills
#
# SSH with specific key (multi GitHub account):
#   REPO=git@github.com:org/repo.git
#   BRANCH=main
#   SKILLS_SUBDIR=skills
#   SSH_KEY=~/.ssh/id_ed25519_work
#
# HTTPS with token (private repo):
#   REPO=https://github.com/org/repo.git
#   BRANCH=main
#   SKILLS_SUBDIR=skills
#   GIT_TOKEN_ENV=GITHUB_TOKEN
#
# Local directory (development):
#   REPO=~/projects/my-skills
#   TYPE=local
#   SKILLS_SUBDIR=skills

# --- Required ---
REPO=https://github.com/your-org/your-skills-repo.git
BRANCH=main
SKILLS_SUBDIR=skills

# --- Optional ---
# TYPE=git
# SSH_KEY=
# GIT_TOKEN_ENV=
